@model IEnumerable<Vidly.Models.Movie>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}



<table id="movies" class="table table-striped mt-2">
    <thead class="bg-primary">
        <tr>
            <th>Movie</th>
            <th>Genre</th>

        </tr>
    </thead>
    <tbody>
    </tbody>

</table>

@section Scripts{
    <script>

        $(document).ready(function () {

            $('#movies').DataTable({
                ajax: {
                    url: "/api/Movies/",
                    dataSrc: ""

                },
                columns: [
                    {
                        data: "name"

                        
                    },
                    {
                        data: "genre.name"
                    }
                ]
            });
           

        });
    </script>
    }

