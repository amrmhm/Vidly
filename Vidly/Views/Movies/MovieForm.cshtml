@model Vidly.ViewModel.MovieFormViewModel
@{
    ViewBag.Title = "New";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@Model.Title</h2>

@using (Html.BeginForm("Save", "Movies"))
{
    @Html.ValidationSummary(true , "Please Fixed Errors :")
    <div class="form-group">
        @Html.LabelFor(c => c.Name)
        @Html.TextBoxFor(c => c.Name, new { @class = "form-control" })
        @Html.ValidationMessageFor(c => c.Name )
    </div>
    <div class="form-group">
        @Html.LabelFor(c => c.RelaseDate)
        @Html.TextBoxFor(c => c.RelaseDate, "{0:d MMM yyyy}", new { @class = "form-control" })
        @Html.ValidationMessageFor(c => c.RelaseDate)

    </div>
    <div class="form-group">
        @Html.LabelFor(c => c.GenreId)
        @Html.DropDownListFor(c => c.GenreId, new SelectList(Model.Genre, "Id", "Name"), "Select Genre", new { @class = "form-control" })
        @Html.ValidationMessageFor(c => c.GenreId)

    </div>
    <div class="form-group">
        @Html.LabelFor(c => c.NumberOfStock)
        @Html.TextBoxFor(c => c.NumberOfStock, new { @class = "form-control" })
        @Html.ValidationMessageFor(c => c.NumberOfStock)

    </div>

    @Html.HiddenFor(c => c.Id)
    @Html.AntiForgeryToken()
    <button type="submit" class="btn btn-primary">Save</button>

}

@section Scripts{
    @Scripts.Render("~/bundles/jqueryval")
    }