@model IEnumerable<Vidly.Models.Movie>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Movie</h2>
@Html.ActionLink("New Movie" ,"MovieForm" ,"Movies", new {@class = "btn btn-primary mt-3"})
<br />
<br />

<table id="movies" class="table table-striped mt-2">
    <thead class="bg-primary">
        <tr>
            <th>Movie</th>
            <th>Genre</th>
            <th>Delete</th>
        </tr>
    </thead>
    <tbody>
    </tbody>

</table>

@section Scripts{
    <script>

        $(document).ready(function () {

            $('#movies').DataTable({
                ajax: {
                    url: "/api/Movies/",
                    dataSrc: ""

                },
                columns: [
                    {
                        data: "name",
                        render: function (data, type, movie) {
                            return "<a href = '/movies/Edit/" + movie.id + "' >" + movie.name + "</a";

                        }
                    },
                    {
                        data: "genre.name"
                    },
                    {
                        data: "id",
                        render: function (data, type, row) {
                            return "<button class = 'btn btn-primary js-delete' data-movie-id =" + row.id + "> Delete </button>";
                        }
                    }
                ]
            });
            $('#movies').on('click', ".js-delete", function () {
                var btn = $(this);

                bootbox.confirm({
                    message: 'Are You Sure Delete This Customers?',
                    buttons: {
                        confirm: {
                            label: 'Yes',
                            className: 'btn-danger'
                        },
                        cancel: {
                            label: 'No',
                            className: 'btn-success'
                        }
                    },
                    callback: function (result) {
                        if (result) {

                            $.ajax({
                                url: "/api/movies/" + btn.attr("data-movie-id"),  //or  btn.data('id')
                                method: "DELETE",
                                success: function () {
                                    //table.row(btn.parents('tr')).remove().draw();
                                    btn.parents('tr').fadeOut();

                                },
                                error: function () {

                                    alert("Somthing We Wrong Errors");
                                }

                            });


                        }
                    }
                });


            });

        });
    </script>
    }

