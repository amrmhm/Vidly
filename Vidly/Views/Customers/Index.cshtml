@model IEnumerable<Vidly.Models.Customer>
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>Customer</h2>
<a href="/Customers/CustomerForm " class="btn btn-primary mt-2">New Customer</a>
<br />
<br />

<table id="customerss" class="table table-striped mt-2">
    <thead class="bg-primary">
        <tr>
            <th>Customer</th>
            <th>Member Ship Type</th>
            <th>Delete</th>
        </tr>
    </thead>
    <tbody>
    </tbody>

</table>



@section Scripts{

    <script>
        $(document).ready(function () {
           var table = $('#customerss').DataTable({
              
                ajax: {
                    url: "/api/customers" ,
                    dataSrc : ""


                },
               
                columns: [
                    {
                        data: "name",
                        render: function (data, type, customer) {
                            return "<a href='/customers/Edit/" + customer.id + "'>" + customer.name + "</a>";
                        }
                    },


                    {
                        data: "memberShipType.name",
                    },
                    {
                        data : "id" ,
                        render: function (data, type, row) {
                            return "<button class ='btn btn-primary js-delete' data-customer-id =" + row.id + ">Delete </button>"
                        }
                    }




                ]
            });

            $('#customerss').on('click', ".js-delete", function () {
                var btn = $(this);
                bootbox.confirm({
                    message: 'Are You Sure Delete This Customers?',
                    buttons: {
                        confirm: {
                            label: 'Yes',
                            className: 'btn-danger'
                        },
                        cancel: {
                            label: 'No',
                            className: 'btn-success'
                        }
                    },
                    callback: function (result) {
                        if (result) {

                            $.ajax({
                                url: "/api/customers/" + btn.attr("data-customer-id"),  //or  btn.data('id')
                                method: "DELETE",
                                success: function () {
                                    //table.row(btn.parents('tr')).remove().draw();
                                    btn.parents('tr').fadeOut();
                                   
                                },
                                error: function () {

                                    alert("Somthing We Wrong Errors");
                                }

                            });


                        }
                    }
                });

            });
        });

    </script>


}
